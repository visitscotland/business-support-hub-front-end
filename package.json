{
  "name": "nuxt-bloomreach-headless-white-label",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "postinstall": "node -p \"require('./node_modules/@visitscotland/component-library/package.json').version\" > .clversion && nuxt prepare",
    "commit": "cz",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "lint": "eslint ./**/*.{js,vue,ts}",
    "lint:fix": "yarn lint --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,vue,ts}": "eslint"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/scripts": "^1.1.0",
    "@nuxtjs/dotenv": "^1.4.2",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@vue/eslint-config-airbnb": "^8.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nuxt": "~4.4.8",
    "nuxt-lazy-hydrate": "^1.0.0"
  },
  "dependencies": {
    "@bloomreach/spa-sdk": "^27.3.1",
    "@bloomreach/vue3-sdk": "^22.0.5",
    "@pinia/nuxt": "^0.11.3",
    "@visitscotland/component-library": "^5.57.4",
    "aws-rum-web": "^3.1.0",
    "axios": "^1.16.1",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "mitt": "^3.0.0",
    "nuxt-jsonld": "^2.2.1",
    "pinia": "^3.0.4",
    "sass": "^1.100.0",
    "standard-version": "^9.5.0",
    "typescript": "^6.0.3",
    "unenv": "^1.10.0",
    "youtube-vue3": "^0.1.15"
  },
  "overrides": {
    "minimist": "latest",
    "minimatch": "^10.2.5",
    "lodash": "^4.18.0",
    "axios": "^1.16.1"
  },
  "resolutions": {
    "minimist": "latest",
    "minimatch": "^10.2.5",
    "lodash": "^4.18.0",
    "axios": "^1.16.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "yarn@4.14.1"
}
